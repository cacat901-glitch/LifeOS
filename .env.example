# ============================================================
# Novus Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# Database (Neon / Supabase / Railway — all free tier available)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Authentication
NEXTAUTH_URL="https://your-app.vercel.app"
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"

# ── Novus AI ──────────────────────────────────────────────────
# Novus auto-detects which provider to use based on the key present.
#
# RECOMMENDED: Groq — free, no credit card, works worldwide (incl. EU/UK), very fast.
#   1. Go to https://console.groq.com/keys
#   2. Sign up (free) and create an API key
#   3. Paste below. Novus will use Groq automatically.
GROQ_API_KEY="gsk_..."

# Google Gemini (alternative). NOTE: the free tier is NOT available in the
# EU/UK — those projects get quota limit:0 and require billing to be enabled.
#   Key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY="your-gemini-api-key"

# Optional: force a specific provider ("groq" | "gemini"). If unset, Novus
# auto-detects: Groq key first, then Gemini, then offline fallback.
# NOVUS_AI_PROVIDER="groq"

# ── Google OAuth (free) ──────────────────────────────────────
# 1. Go to https://console.cloud.google.com
# 2. Create project → APIs & Services → Credentials → Create OAuth client
# 3. Application type: Web, Name: Novus
# 4. Authorized redirect URIs: https://your-app.vercel.app/api/auth/callback/google
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ── Stripe (free in test mode) ───────────────────────────────
# 1. Go to https://dashboard.stripe.com (keep in Test Mode)
# 2. Create a Product "Pro" with price $9.99/month recurring
# 3. Copy the Price ID (starts with price_)
# 4. For webhook: stripe listen --forward-to localhost:3000/api/stripe/webhook
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRO_PRICE_ID="price_..."

# ── Resend (free tier: 3,000 emails/month) ───────────────────
# 1. Go to https://resend.com → Sign up → Create API key
# 2. (Optional) Add & verify your domain for custom from address
# 3. Without a domain, emails send from onboarding@resend.dev
RESEND_API_KEY="re_..."

# App URL (used in emails and OAuth redirects)
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"
NEXT_PUBLIC_APP_NAME="Novus"
